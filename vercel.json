{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/client/dist/assets/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/client/dist/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "/client/dist/sw.js"
    },
    {
      "src": "/favicon.svg",
      "dest": "/client/dist/favicon.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/index.html"
    }
  ]
}
